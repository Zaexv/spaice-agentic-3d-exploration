# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# AI Model (optional, defaults to gemini-2.0-flash)
# VITE_AI_MODEL=gemini-2.0-flash

# AI Base URL (optional, defaults to Google's OpenAI-compatible endpoint)
# VITE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control
